# ─────────────────────────────────────────────────────────────────────────────
# PlacementIQ Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ---------------------------------------------------------------------------
# Groq API (required for LLM features: risk narrative, resume scanner,
# interview analysis, and Whisper transcription)
# Get your key at: https://console.groq.com/
# ---------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ---------------------------------------------------------------------------
# Supabase (optional — only needed for production auth)
# If not set, the backend falls back to the "demo-local-token" bypass.
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=8000
